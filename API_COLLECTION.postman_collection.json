{
  "info": {
    "_postman_id": "reachinbox-scheduler",
    "name": "ReachInbox Email Scheduler",
    "description": "API endpoints for scheduling and managing emails",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/health",
          "host": ["{{base_url}}"],
          "path": ["health"]
        }
      }
    },
    {
      "name": "Schedule Emails",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"subject\": \"Welcome to ReachInbox\",\n  \"body\": \"Hi {{email}}, thanks for signing up!\",\n  \"emails\": [\"user1@example.com\", \"user2@example.com\", \"user3@example.com\"],\n  \"senderEmail\": \"noreply@reachinbox.com\",\n  \"startTime\": \"2026-01-20T16:00:00Z\",\n  \"delayBetweenSends\": 2000,\n  \"hourlyLimit\": 100\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/schedule",
          "host": ["{{base_url}}"],
          "path": ["api", "schedule"]
        }
      }
    },
    {
      "name": "Get Scheduled Emails",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/api/scheduled?limit=20&offset=0",
          "host": ["{{base_url}}"],
          "path": ["api", "scheduled"],
          "query": [
            {
              "key": "limit",
              "value": "20"
            },
            {
              "key": "offset",
              "value": "0"
            }
          ]
        }
      }
    },
    {
      "name": "Get Sent Emails",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/api/sent?limit=20&offset=0",
          "host": ["{{base_url}}"],
          "path": ["api", "sent"],
          "query": [
            {
              "key": "limit",
              "value": "20"
            },
            {
              "key": "offset",
              "value": "0"
            }
          ]
        }
      }
    },
    {
      "name": "Get Pending Emails",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/api/pending?limit=20&offset=0",
          "host": ["{{base_url}}"],
          "path": ["api", "pending"],
          "query": [
            {
              "key": "limit",
              "value": "20"
            },
            {
              "key": "offset",
              "value": "0"
            }
          ]
        }
      }
    },
    {
      "name": "Get Statistics",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/api/stats",
          "host": ["{{base_url}}"],
          "path": ["api", "stats"]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3001",
      "type": "string"
    }
  ]
}
