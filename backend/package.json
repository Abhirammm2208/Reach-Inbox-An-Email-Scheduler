{
  "name": "reachinbox-backend",
  "version": "1.0.0",
  "description": "Email scheduler service for ReachInbox",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "worker": "ts-node --transpile-only src/worker.ts",
    "typeorm": "typeorm",
    "migrate": "ts-node node_modules/typeorm/cli.js migration:run -d src/db/connection.ts",
    "migrate:generate": "ts-node node_modules/typeorm/cli.js migration:generate -d src/db/connection.ts",
    "seed": "ts-node --transpile-only src/db/seed.ts"
  },
  "keywords": [
    "email",
    "scheduler",
    "bullmq",
    "redis"
  ],
  "author": "ReachInbox",
  "license": "ISC",
  "dependencies": {
    "bullmq": "^5.12.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "ioredis": "^5.4.1",
    "nodemailer": "^6.9.10",
    "pg": "^8.11.5",
    "typeorm": "^0.3.20",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.22",
    "@types/node": "^20.12.5",
    "@types/nodemailer": "^6.4.14",
    "@types/uuid": "^9.0.7",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.4"
  }
}
